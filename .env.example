# ─────────────────────────────────────────────────────────────────────────────
# Patiently — environment configuration
# Copy to `.env` at the repo root. Every value below has a safe default, so the
# app runs end-to-end with NO keys (it uses seeded mock price feeds). Add real
# keys to flip individual stores over to live data — no code change required.
# ─────────────────────────────────────────────────────────────────────────────

# --- Middleware (API gateway) ---
MIDDLEWARE_PORT=4000
# Comma-separated list of allowed web/mobile origins for CORS.
CORS_ORIGINS=http://localhost:5173
# Secret used to sign session JWTs. CHANGE THIS in any real deployment.
JWT_SECRET=dev-only-change-me

# --- Backend (domain core) ---
# Where the JSON-file repository persists data (swap for Postgres in prod).
DATA_DIR=./data
# Default currency + destination used for landed-cost (shipping/tax) estimates.
DEFAULT_CURRENCY=INR
DEFAULT_DESTINATION_COUNTRY=IN
DEFAULT_DESTINATION_POSTAL=560001
# India listed prices include GST, so the default extra-tax rate is 0. Set a
# fraction only for a store/destination that quotes prices excluding tax.
DEFAULT_TAX_RATE=0

# --- Daily search scheduler ---
# When true, the middleware runs the daily-search worker on an interval in-process
# (handy for local demos). In production prefer an external cron hitting
# POST /api/jobs/daily-search. Interval is in minutes.
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_MINUTES=1440
# Shared secret required to trigger the job endpoint (cron -> middleware).
JOB_TRIGGER_TOKEN=dev-only-job-token

# --- Real India e-commerce store adapters (all optional) ---
# Leave blank to use the deterministic mock feed for that store. Croma, Reliance
# Digital, Tata CLiQ and Myntra always use the mock feed (no live adapter yet).

# Amazon India Product Advertising API v5 (Amazon Associates India).
# https://webservices.amazon.com/paapi5/documentation/
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.in
AMAZON_REGION=eu-west-1
AMAZON_MARKETPLACE=www.amazon.in

# Flipkart Affiliate API (https://affiliate.flipkart.com/api-docs/af-doc.html)
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=

# Partner storefront APIs — Croma, Reliance Digital, Tata CLiQ, Myntra.
# These chains have no open product API; supply a partner/affiliate base URL +
# API key per store to activate its live integration (else it uses the mock
# feed). The adapter normalises each response to a common product shape.
CROMA_API_BASE=
CROMA_API_KEY=
RELIANCE_DIGITAL_API_BASE=
RELIANCE_DIGITAL_API_KEY=
TATA_CLIQ_API_BASE=
TATA_CLIQ_API_KEY=
MYNTRA_API_BASE=
MYNTRA_API_KEY=

# --- Push notifications (Firebase Cloud Messaging) ---
# Service-account credentials. When unset, the backend uses a log-only push
# sender (the approve-to-buy flow still works; pushes are just logged).
# From your Firebase service-account JSON: project_id, client_email, private_key.
# Keep the private key's literal "\n" escapes — they're un-escaped at runtime.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Frontend ---
# Base URL the web/mobile client uses to reach the middleware API.
VITE_API_BASE_URL=http://localhost:4000
